# Local dev only — used when running via compose.dev.yml.
# This file is volume-mounted into the container at /usr/src/app/.env and read by dotenv.
#
# In production, env vars are injected by Docker Compose via env_file: '.env' (the root .env),
# which is written by Terraform on first boot. This file is not used in production.

APP_PORT=3000

SECRET_KEY=

# These must match root .env
DB_NAME=app
DB_HOST=db
DB_USER=postgres
DB_PASSWORD=password
DB_PORT=5432