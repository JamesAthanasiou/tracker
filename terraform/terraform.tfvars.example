# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

region        = "us-east-2"

# "test"  → spins up infra but does NOT touch DNS. Safe to run while old server is live.
# "prod"  → updates Route 53 A records to point jamesisonline.com at the new server.
environment   = "test"

domain        = "jamesisonline.com"
instance_type = "t3.nano"

# Use a unique name for test (S3 bucket names are globally unique).
# Use "jamesisonline" for prod.
s3_bucket_name = "jamesisonline-test"

db_name     = "app"
db_user     = "postgres"
db_password = "CHANGE_ME"   # use a strong password
db_port     = "5432"

app_port    = "3000"

# Absolute path to the tracker-client repo on your machine.
# The build output (./dist) gets synced to S3 on apply (prod only).
frontend_path = "/Users/admin/Documents/Code/tracker_client"

# If your backend/.env has additional secrets (JWT keys, third-party API keys, etc.)
# add them as new variables in variables.tf and reference them in user_data.sh.tpl.
